# OIDC provider (e.g. GitLab, Keycloak, Auth0, etc.)
OIDC_ISSUER_URL=https://gitlab.example.com
OIDC_CLIENT_ID=your-oidc-client-id
OIDC_CLIENT_SECRET=your-oidc-client-secret

# IMAP server (default provider; sole entry of the provider allowlist
# unless IMAP_PROVIDERS below is set).
IMAP_HOST=mail.factorial.io
IMAP_PORT=993

# Optional: opt-in additional IMAP providers users may connect to.
# Inline JSON list, or a path to a JSON file. When set, replaces the
# default single-entry allowlist — include your Factorial entry here
# as well if you still want it.
#
# IMAP_PROVIDERS=[{"id":"factorial","label":"Factorial","host":"mail.factorial.io","port":993},{"id":"gmail","label":"Gmail","host":"imap.gmail.com","port":993,"note":"Use an app password"},{"id":"fastmail","label":"Fastmail","host":"imap.fastmail.com","port":993}]
#
# Same data may be supplied via the --imap-providers CLI flag (wins over env).

# Public URL of this service (no trailing slash)
BASE_URL=https://imap-mcp.example.com

# Redis (set by docker-compose, override if external)
REDIS_URL=redis://redis:6379

# 32-byte AES-256 key, base64-encoded
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Logging
RUST_LOG=info

# Traefik hostname (used in docker-compose labels)
TRAEFIK_HOST=imap-mcp.example.com

# ngrok (used in docker-compose.dev.yml)
NGROK_AUTHTOKEN=your-ngrok-authtoken
# Optional: reserved domain (paid ngrok feature, keeps URL stable)
# NGROK_DOMAIN=your-name.ngrok-free.app
