# GitLab OIDC
GITLAB_URL=https://gitlab.factorial.io
GITLAB_CLIENT_ID=your-gitlab-app-client-id
GITLAB_CLIENT_SECRET=your-gitlab-app-client-secret

# IMAP server
IMAP_HOST=imap.factorial.io
IMAP_PORT=993

# Public URL of this service (no trailing slash)
BASE_URL=https://imap-mcp.example.com

# Redis (set by docker-compose, override if external)
REDIS_URL=redis://redis:6379

# 32-byte AES-256 key, base64-encoded
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Logging
RUST_LOG=info

# Traefik hostname (used in docker-compose labels)
TRAEFIK_HOST=imap-mcp.example.com

# ngrok (used in docker-compose.dev.yml)
NGROK_AUTHTOKEN=your-ngrok-authtoken
# Optional: reserved domain (paid ngrok feature, keeps URL stable)
# NGROK_DOMAIN=your-name.ngrok-free.app
